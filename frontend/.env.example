# DayTree - Frontend Environment Variables

# The base URL of the backend API.
# Leave empty in local development to use the Vite proxy (which routes /api to http://localhost:5000).
# In production, set to your deployed backend URL (e.g. https://daytree-backend.onrender.com).
VITE_API_BASE_URL=

# Your Google OAuth Client ID for rendering the Google Sign-In button.
# Obtain this from the Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
